{
  "manifest_version": 3,
  "name": "Jarvis Local Bridge",
  "version": "0.1.0",
  "description": "Injects locally stored memory context into web UIs; talks to Jarvis desktop via native messaging.",
  "permissions": ["storage", "nativeMessaging", "scripting", "activeTab"],
  "host_permissions": [
    "https://chat.openai.com/*",
    "https://chatgpt.com/*",
    "https://claude.ai/*",
    "https://gemini.google.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chat.openai.com/*",
        "https://chatgpt.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*"
      ],
      "js": ["content-bridge.js"],
      "run_at": "document_idle"
    }
  ]
}
