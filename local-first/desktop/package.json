{
  "name": "jarvis-local-core",
  "version": "0.1.0",
  "private": true,
  "description": "Jarvis local-first daemon: tray app + SQLite (user data never leaves device).",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "rebuild:native": "electron-rebuild -f -w better-sqlite3 && electron-rebuild -f -w active-win"
  },
  "dependencies": {
    "active-win": "^8.1.0",
    "better-sqlite3": "^12.9.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.0",
    "electron": "^33.2.0"
  }
}
